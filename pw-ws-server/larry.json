{
  "name": "pw-ws-server",
  "version": "0.1.0",
  "description": "Generic protocol-driven WebSocket server framework",
  "type": "extension",
  "actions": {
    "ws-server-start": {
      "entry": "dist/actions/start.js",
      "description": "Start WebSocket server for session"
    },
    "ws-server-stop": {
      "entry": "dist/actions/stop.js",
      "description": "Stop WebSocket server"
    },
    "ws-server-status": {
      "entry": "dist/actions/status.js",
      "description": "Check WebSocket server status"
    }
  }
}
