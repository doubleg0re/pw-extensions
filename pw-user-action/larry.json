{
  "name": "pw-user-action",
  "version": "0.2.0",
  "description": "Native topmost user-action prompt with browser-overlay fallback",
  "type": "extension",
  "actions": {
    "pw-user-action": {
      "entry": "dist/action-user-action.js",
      "description": "Show a native topmost prompt when available, return the clicked action"
    }
  },
  "hooks": {
    "load": {
      "entry": "dist/load-hook.js"
    }
  },
  "events": {
    "tab:activated": {
      "entry": "dist/on-activated.js"
    },
    "tab:deactivated": {
      "entry": "dist/on-deactivated.js"
    },
    "tab:navigated": {
      "entry": "dist/on-navigated.js"
    },
    "tab:closed": {
      "entry": "dist/on-closed.js"
    },
    "user-action:started": {
      "entry": "dist/on-started.js"
    },
    "user-action:completed": {
      "entry": "dist/on-completed.js"
    }
  }
}
