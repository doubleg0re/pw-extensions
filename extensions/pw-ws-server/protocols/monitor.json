{
  "name": "monitor",
  "version": "0.1.0",
  "description": "pw-monitor state streaming — snapshot on connect, live events via fs.watch",

  "outbound": {
    "snapshot": {
      "description": "Full monitor state sent on connect",
      "schema": {
        "type": "object",
        "properties": {
          "session": { "type": ["object", "null"] },
          "tabs": { "type": "array" },
          "activeTabId": { "type": ["number", "null"] },
          "sidecarPid": { "type": ["number", "null"] },
          "sidecarAlive": { "type": "boolean" },
          "pendingActions": { "type": "array" }
        }
      }
    },
    "event": {
      "description": "Live state change pushed when monitor files change"
    }
  },

  "inbound": {
    "ping": {
      "handler": "../handlers/monitor/ping.ts",
      "schema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },

  "hooks": {
    "onConnect": "../handlers/monitor/on-connect.ts"
  },

  "source": {
    "adapter": "pw-monitor",
    "watch": true
  }
}
