{
  "name": "pw-ws-server",
  "version": "0.1.0",
  "description": "WebSocket transport for pw-monitor state — snapshot on connect, live events, bidirectional actions",
  "type": "extension",
  "actions": {
    "ws-server-start": {
      "entry": "src/actions/start.ts",
      "description": "Start WebSocket server for session"
    },
    "ws-server-stop": {
      "entry": "src/actions/stop.ts",
      "description": "Stop WebSocket server"
    },
    "ws-server-status": {
      "entry": "src/actions/status.ts",
      "description": "Check WebSocket server status"
    }
  }
}
